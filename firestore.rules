rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper: Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data != null ? resource.data : {}).affectedKeys().hasOnly(['karmaTotal', 'karmaWeekly'])
      );
    }

    // 2. Posts Collection
    match /posts/{postId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() &&
        request.resource.data.authorId == request.auth.uid &&
        request.resource.data.keys().hasAll(['authorId', 'lat', 'lng', 'headline', 'category']);
      
      allow update: if isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['verifiedCount', 'flagCount', 'reactions', 'isHidden']) &&
        resource.data.authorId == request.resource.data.authorId &&
        (request.resource.data.isHidden == resource.data.isHidden || 
         request.auth.uid == resource.data.authorId || 
         request.auth.uid == 'PDSS7Le4eDZetKMw6fBaI5zDaer1');
        
      allow delete: if isAuthenticated() && 
        (request.auth.uid == resource.data.authorId || request.auth.uid == 'PDSS7Le4eDZetKMw6fBaI5zDaer1');
    }

    // 3. Verifications Collection
    match /verifications/{docId} {
      allow read: if isAuthenticated();
      // docId is {postId}_{userId}
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // 4. Flags Collection
    match /flags/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    // 5. Bus Anchors (Radar Stops)
    match /bus_anchors/{anchorId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.verified == false &&
        request.resource.data.suggestedBy == request.auth.uid;
      // Updates and deletes are reserved for admins (manual verification)
      allow update, delete: if isAuthenticated() && request.auth.uid == 'PDSS7Le4eDZetKMw6fBaI5zDaer1';
    }
  }
}
