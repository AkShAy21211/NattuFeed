rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Generic storage access (public reads, user-specific writes)
    match /post_images/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'YIk8fYx3n9Uwj4ygF4tnwVGFS8p2');
    }
    
    // Default fallback (closed)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
